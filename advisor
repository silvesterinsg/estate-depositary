<script>
// ── CONFIG ──────────────────────────────────────────────
var GAS_URL = 'https://script.google.com/macros/s/AKfycbx2BScnbDAYx9nfGrLLFyxv7LiHa5o3H8xmcaeWSkQ7LzjE1V7gh04JdcSElnznK-8n/exec';
var ADVISOR_PASSWORD = 'Precepts2024!'; // ← Change this to your preferred password

var ALL_CLIENTS = [];

// Asset type labels
var AT_LABELS = {
  property:'Property',vehicles:'Vehicles',bankAccounts:'Bank Accounts',
  business:'Business Ownership',safeDeposit:'Safe Deposit Box',
  collectibles:'Collectibles & Valuables',investments:'Investment Accounts',
  digital:'Digital Assets',retirement:'Retirement Accounts',
  ip:'Intellectual Property',insurance:'Life Insurance Policies',others:'Others'
};

// Complexity sections
var CS=[
  {k:'property',i:'🏠',t:'Property',q:[
    {k:'ph',l:'How is your property being owned?',st:true},
    {k:'pt',l:'Type of property'},{k:'po',l:'Ownership structure'},
    {k:'at2',l:'Automatic transfer upon passing?'},{k:'ol',l:'Outstanding loan?'},
    {k:'fh',l:'Remain as family home?'},{k:'cd',l:'Common disaster — who owns?'},
    {k:'fm',l:'Beneficiaries have financial means?'},{k:'lm',l:'Limitations to transfer?'},
    {k:'rl',l:'Will transfer affect relationships?'}
  ]},
  {k:'joint',i:'🤝',t:'Joint Account',q:[
    {k:'hj',l:'Assets in joint names?'},{k:'ct',l:'Who contributed?'},
    {k:'so',l:'Give to surviving joint owner?'}
  ]},
  {k:'loans',i:'💳',t:'Loans & Liabilities',q:[
    {k:'hl',l:'Outstanding debts or liabilities?'},{k:'st2',l:'Loans/mortgages settlement planned?'},
    {k:'di',l:'Insurance covering debts?'}
  ]},
  {k:'invest',i:'📈',t:'Investment Accounts',q:[
    {k:'ih',l:'How would you like your investments to be managed?',st:true},
    {k:'il',l:'Where are investments based?'},{k:'iw',l:'Subject to different inheritance laws?'},
    {k:'ib',l:'Beneficiaries know how to manage?'}
  ]},
  {k:'overseas',i:'✈️',t:'Overseas Assets',q:[
    {k:'ho',l:'Assets in multiple countries?'},{k:'fh2',l:'Checked forced heirship laws?'},
    {k:'sw',l:'Separate Wills for each country?'}
  ]},
  {k:'cpf',i:'🏦',t:'CPF',q:[
    {k:'ch',l:'How would you like your CPF monies to be distributed?',st:true},
    {k:'cn',l:'CPF nomination done?'},{k:'cp',l:'Lump sum or Trust?'}
  ]},
  {k:'ins',i:'🛡️',t:'Life Insurance',q:[
    {k:'ish',l:'How would you like your insurance payout to be distributed?',st:true},
    {k:'in2',l:'Insurance nominations done?'},{k:'ic',l:'Consolidated through Will?'}
  ]},
  {k:'col',i:'💎',t:'Collectibles & Valuables',q:[
    {k:'coh',l:'How will your beneficiaries manage each item?',st:true},
    {k:'inf',l:'Beneficiary informed/labelled?'},{k:'apr',l:'Beneficiary will appreciate item?'}
  ]},
  {k:'biz',i:'🏢',t:'Business',q:[
    {k:'hb',l:'Business needs succession planning?'},{k:'sc3',l:'Successor identified?'},
    {k:'bs',l:'Buy-sell agreement considered?'},{k:'ke',l:'Key employees to inherit?'}
  ]},
  {k:'dig',i:'💻',t:'Digital Assets',q:[
    {k:'dh',l:'How will your beneficiaries know the existence of these accounts?',st:true},
    {k:'ac2',l:'Access codes written down?'}
  ]}
];

// JSONP helper
var _n=0;
function api(action,params,cb){
  var name='_cb'+(++_n);
  var url=GAS_URL+'?action='+action+'&callback='+name;
  Object.keys(params).forEach(function(k){url+='&'+k+'='+encodeURIComponent(params[k]);});
  window[name]=function(d){delete window[name];document.head.removeChild(document.getElementById(name));cb(null,d);};
  var s=document.createElement('script');s.id=name;s.src=url;
  s.onerror=function(){cb(new Error('failed'),null);};
  document.head.appendChild(s);
}

// LOGIN
function doAdvisorLogin(){
  var p=document.getElementById('ap').value;
  var e=document.getElementById('aerr');
  e.style.display='none';
  if(p===ADVISOR_PASSWORD){
    document.getElementById('loginScreen').classList.remove('active');
    document.getElementById('appScreen').classList.add('active');
    loadClients();
  } else {
    e.textContent='Incorrect password.';e.style.display='block';
  }
}

function doLogout(){
  document.getElementById('appScreen').classList.remove('active');
  document.getElementById('loginScreen').classList.add('active');
  document.getElementById('ap').value='';
  ALL_CLIENTS=[];
}

// LOAD ALL CLIENTS
function loadClients(){
  api('getAllClients',{},function(err,data){
    if(err||!data||!data.clients){
      document.getElementById('clientList').innerHTML='<div class="no-clients">Could not load clients.</div>';
      return;
    }
    ALL_CLIENTS=data.clients;
    renderStats(data);
    renderClientList(ALL_CLIENTS);
  });
}

function renderStats(data){
  document.getElementById('statTotal').textContent=data.clients.length;
  document.getElementById('statAssets').textContent=data.clients.filter(function(c){return c.hasAssets;}).length;
  document.getElementById('statComplete').textContent=data.clients.filter(function(c){return c.hasAssets&&c.hasComplexity;}).length;
}

function renderClientList(clients){
  var el=document.getElementById('clientList');
  if(!clients.length){el.innerHTML='<div class="no-clients">No clients found.</div>';return;}
  el.innerHTML=clients.map(function(c){
    var ab=c.hasAssets&&c.hasComplexity?'<span class="badge badge-done">Complete</span>':
           c.hasAssets||c.hasComplexity?'<span class="badge badge-partial">In Progress</span>':
           '<span class="badge badge-none">Not Started</span>';
    return '<div class="client-row" onclick="showClient(\''+c.clientId+'\')"><div><div class="client-name">'+c.name+'</div><div class="client-meta">'+c.email+' &nbsp;·&nbsp; '+formatDate(c.createdAt)+'</div></div><div class="client-badges">'+ab+'<span class="chevron">›</span></div></div>';
  }).join('');
}

function filterClients(){
  var q=document.getElementById('searchBar').value.toLowerCase();
  var filtered=ALL_CLIENTS.filter(function(c){
    return c.name.toLowerCase().includes(q)||c.email.toLowerCase().includes(q);
  });
  renderClientList(filtered);
}

// CLIENT DETAIL
function showClient(clientId){
  var c=ALL_CLIENTS.find(function(x){return x.clientId===clientId;});
  if(!c)return;
  document.getElementById('listView').style.display='none';
  document.getElementById('detailView').style.display='block';
  document.getElementById('dName').textContent=c.name;
  document.getElementById('dEmail').textContent=c.email;
  document.getElementById('dUser').textContent=c.username;
  document.getElementById('dPass').textContent=c.password;
  document.getElementById('dId').textContent=c.clientId;
  document.getElementById('dCreated').textContent=formatDate(c.createdAt);
  document.getElementById('dAssets').innerHTML='<div class="loading">Loading assets...</div>';
  document.getElementById('dComplexity').innerHTML='';

  api('getAssets',{clientId:clientId},function(err,assets){
    renderAssets(assets||{});
  });
  api('getComplexity',{clientId:clientId},function(err,complexity){
    renderComplexity(complexity||{});
  });
}

function showList(){
  document.getElementById('detailView').style.display='none';
  document.getElementById('listView').style.display='block';
}

function renderAssets(ad){
  var types=(ad.types||[]);
  var html='<div class="detail-card"><div class="detail-title">Asset Inventory</div>';
  if(!types.length){html+='<div class="no-data">No assets recorded yet.</div>';}
  else{
    html+='<div class="asset-tags">'+types.map(function(k){return'<span class="atag">'+(AT_LABELS[k]||k)+'</span>';}).join('')+'</div>';
    if(ad.ot)html+='<div class="detail-row"><span class="detail-row-label">Other assets</span><span class="detail-row-val">'+ad.ot+'</span></div>';
    var locs=[];
    if(ad.lsg)locs.push('Singapore');
    if(ad.los)locs.push('Overseas');
    if(ad.lot)locs.push(ad.lotx||'Others');
    if(locs.length)html+='<div class="detail-row"><span class="detail-row-label">Asset locations</span><span class="detail-row-val">'+locs.join(', ')+'</span></div>';
    if(ad.sc)html+='<div class="detail-row"><span class="detail-row-label">Planning scope</span><span class="detail-row-val">'+ad.sc+(ad.sotx?' ('+ad.sotx+')'):'')+'</span></div>';
    if(ad.notes)html+='<div class="detail-row"><span class="detail-row-label">Notes</span><span class="detail-row-val">'+ad.notes+'</span></div>';
  }
  html+='</div>';
  document.getElementById('dAssets').innerHTML=html;
}

function renderComplexity(cd){
  var html='<div class="detail-title" style="font-family:Cormorant Garamond,serif;font-size:17px;font-weight:500;color:#6B1A2A;margin-bottom:10px;">Asset Complexity Responses</div>';
  html+=CS.map(function(sec){
    var secData=cd[sec.k]||{};
    var answerableQs=sec.q.filter(function(q){return !q.st;});
    var answered=answerableQs.filter(function(q){return secData[q.k];}).length;
    var statusTxt=answered===0?'Not started':answered<answerableQs.length?answered+'/'+answerableQs.length+' answered':'Complete ✓';
    var statusColor=answered===0?'#6B7280':answered<answerableQs.length?'#92400E':'#065F46';
    var qsHtml=sec.q.map(function(q){
      if(q.st)return'<div class="qa-stmt">'+q.l+'</div>';
      var val=secData[q.k]||'—';
      var cls=val==='Yes'?'yes':val==='No'?'no':val==='—'?'':'other';
      return'<div class="qa-row"><span class="qa-q">'+q.l+'</span><span class="qa-a '+cls+'">'+val+'</span></div>';
    }).join('');
    return'<div class="acc" id="acc-'+sec.k+'"><div class="acc-h" onclick="tgAcc(\''+sec.k+'\')"><span class="acc-title">'+sec.i+' '+sec.t+'</span><div style="display:flex;align-items:center;gap:8px"><span class="acc-status" style="color:'+statusColor+'">'+statusTxt+'</span><span class="acc-arrow">▾</span></div></div><div class="acc-body">'+qsHtml+'</div></div>';
  }).join('');
  document.getElementById('dComplexity').innerHTML=html;
}

function tgAcc(k){document.getElementById('acc-'+k).classList.toggle('open');}

function formatDate(str){
  if(!str)return'—';
  try{var d=new Date(str);return d.toLocaleDateString('en-SG',{day:'numeric',month:'short',year:'numeric'});}
  catch(e){return str;}
}

document.getElementById('ap').addEventListener('keydown',function(e){if(e.key==='Enter')doAdvisorLogin();});
</script>

