<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Advisor Dashboard — Estate Planning with Silvester</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100%;overflow-x:hidden;font-family:'DM Sans',sans-serif;font-size:15px;background:#FAF7F2;color:#1C1410;-webkit-text-size-adjust:100%}
:root{
  --gold:#B8962E;--gold-light:#D4AF5A;--gold-pale:#F5EDD6;
  --maroon:#6B1A2A;--maroon-dark:#4A1019;--maroon-light:#8B2235;
  --cream:#FAF7F2;--border:#E8DFD0;--success:#2D7A4A;--error:#B0312A;
  --ink:#1C1410;--ink-mid:#4A3728;--ink-soft:#7A6455;
}

/* SCREENS */
.screen{display:none}.screen.active{display:block}

/* LOGIN */
.login-bg{min-height:100vh;background:var(–maroon-dark);display:flex;align-items:center;justify-content:center;padding:24px 20px}
.login-card{background:#fff;border-radius:8px;padding:32px 24px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.4)}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.crest{width:44px;height:44px;min-width:44px;background:var(–maroon);color:var(–gold-light);border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:‘Cormorant Garamond’,serif;font-size:24px;font-weight:500}
.brand-name{font-family:‘Cormorant Garamond’,serif;font-size:16px;font-weight:600;color:#1C1410;line-height:1.3}
.brand-sub{font-size:10px;color:#7A6455;letter-spacing:0.08em;text-transform:uppercase;margin-top:2px}
.login-intro{font-size:13px;color:#7A6455;line-height:1.6;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(–border)}
.fg{margin-bottom:14px}
.fg label{display:block;font-size:11px;font-weight:500;letter-spacing:0.07em;text-transform:uppercase;color:#4A3728;margin-bottom:5px}
input[type=text],input[type=password]{width:100%;padding:13px 14px;border:1px solid var(–border);border-radius:6px;background:#FAF7F2;font-family:‘DM Sans’,sans-serif;font-size:16px;color:#1C1410;outline:none;-webkit-appearance:none}
input:focus{border-color:var(–gold);background:#fff}
.err{background:#FEF2F2;border:1px solid #FECACA;color:var(–error);padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:14px;display:none}
.btn{display:block;width:100%;padding:15px;background:var(–maroon);color:var(–gold-light);border:none;border-radius:6px;font-family:‘DM Sans’,sans-serif;font-size:14px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;-webkit-appearance:none;text-align:center}
.btn:active{background:var(–maroon-light)}
.btn.sm{width:auto;padding:10px 20px;font-size:12px}

/* APP */
#appScreen{min-height:100vh}
.topbar{background:var(–maroon-dark);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.topbar-brand{font-family:‘Cormorant Garamond’,serif;font-size:15px;color:var(–gold-light);font-weight:500}
.topbar-right{display:flex;align-items:center;gap:12px}
.advisor-badge{font-size:11px;color:rgba(255,255,255,0.5);letter-spacing:0.05em;text-transform:uppercase}
.btn-out{padding:8px 14px;background:transparent;border:1px solid rgba(184,150,46,0.3);color:var(–gold-light);border-radius:4px;font-size:11px;letter-spacing:0.07em;text-transform:uppercase;cursor:pointer;font-family:‘DM Sans’,sans-serif;-webkit-appearance:none}

.main{padding:24px 20px 40px;max-width:900px;margin:0 auto}

/* STATS */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px}
.stat-card{background:#fff;border:1px solid var(–border);border-radius:6px;padding:16px}
.stat-label{font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#7A6455;margin-bottom:4px}
.stat-value{font-family:‘Cormorant Garamond’,serif;font-size:32px;font-weight:500;color:var(–maroon)}

/* CLIENT LIST */
.section-title{font-family:‘Cormorant Garamond’,serif;font-size:20px;font-weight:500;color:var(–ink);margin-bottom:14px}
.search-bar{width:100%;padding:11px 14px;border:1px solid var(–border);border-radius:6px;background:#fff;font-family:‘DM Sans’,sans-serif;font-size:14px;color:var(–ink);outline:none;margin-bottom:14px;-webkit-appearance:none}
.search-bar:focus{border-color:var(–gold)}
.client-list{display:flex;flex-direction:column;gap:8px}
.client-row{background:#fff;border:1px solid var(–border);border-radius:6px;padding:14px 16px;cursor:pointer;transition:border-color 0.2s;display:flex;align-items:center;justify-content:space-between}
.client-row:hover{border-color:var(–gold)}
.client-name{font-weight:500;font-size:15px;color:var(–ink)}
.client-meta{font-size:12px;color:#7A6455;margin-top:2px}
.client-badges{display:flex;gap:6px;flex-shrink:0;margin-left:12px}
.badge{padding:3px 8px;border-radius:3px;font-size:11px;font-weight:500}
.badge-done{background:#D1FAE5;color:#065F46}
.badge-partial{background:#FEF3C7;color:#92400E}
.badge-none{background:#F3F4F6;color:#6B7280}
.chevron{color:#7A6455;font-size:14px;margin-left:8px;flex-shrink:0}
.no-clients{text-align:center;padding:40px;color:#7A6455;font-size:14px;font-style:italic}

/* CLIENT DETAIL */
.back-btn{display:flex;align-items:center;gap:6px;color:var(–gold);font-size:13px;cursor:pointer;margin-bottom:20px;background:none;border:none;font-family:‘DM Sans’,sans-serif;padding:0}
.client-header{background:#fff;border:1px solid var(–border);border-radius:6px;padding:20px;margin-bottom:16px}
.client-header-name{font-family:‘Cormorant Garamond’,serif;font-size:24px;font-weight:500;color:var(–ink);margin-bottom:4px}
.client-header-meta{font-size:13px;color:#7A6455}
.client-header-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid var(–border)}
.meta-item label{font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#7A6455;display:block;margin-bottom:2px}
.meta-item span{font-size:13px;color:var(–ink);font-family:monospace}

/* ASSET SECTION */
.detail-card{background:#fff;border:1px solid var(–border);border-radius:6px;padding:18px;margin-bottom:14px}
.detail-title{font-family:‘Cormorant Garamond’,serif;font-size:17px;font-weight:500;color:var(–maroon);margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid var(–border)}
.asset-tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}
.atag{background:var(–gold-pale);border:1px solid rgba(184,150,46,0.3);color:#4A3728;padding:5px 10px;border-radius:4px;font-size:12px;font-weight:500}
.detail-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(–border);font-size:13px}
.detail-row:last-child{border-bottom:none}
.detail-row-label{color:#7A6455}
.detail-row-val{color:var(–ink);font-weight:500;text-align:right;max-width:60%}
.no-data{color:#7A6455;font-size:13px;font-style:italic}

/* COMPLEXITY */
.acc{border:1px solid var(–border);border-radius:6px;margin-bottom:8px;overflow:hidden;background:#fff}
.acc-h{padding:12px 14px;display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.acc-h:hover{background:var(–gold-pale)}
.acc-title{font-family:‘Cormorant Garamond’,serif;font-size:15px;font-weight:500;color:var(–maroon);display:flex;align-items:center;gap:8px}
.acc-status{font-size:11px;font-weight:500}
.acc-arrow{color:var(–gold);transition:transform 0.3s}
.acc.open .acc-arrow{transform:rotate(180deg)}
.acc-body{display:none;padding:4px 14px 14px;border-top:1px solid var(–border)}
.acc.open .acc-body{display:block}
.qa-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(–border);font-size:13px}
.qa-row:last-child{border-bottom:none}
.qa-q{color:#7A6455;flex:1;padding-right:12px}
.qa-a{font-weight:500;text-align:right;flex-shrink:0}
.qa-a.yes{color:#065F46}.qa-a.no{color:#B0312A}.qa-a.other{color:var(–gold)}
.qa-stmt{font-size:12px;font-style:italic;color:#7A6455;padding:8px 0;border-bottom:1px solid var(–border)}

/* LOADING */
.loading{text-align:center;padding:40px;color:#7A6455;font-size:14px}

@media(max-width:600px){
.stats-row{grid-template-columns:1fr 1fr}
.client-header-grid{grid-template-columns:1fr}
.topbar{padding:12px 16px}
.main{padding:16px 14px 40px}
}
</style>

</head>
